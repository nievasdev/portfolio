---
export interface Props {
  projects: Array<{
    name: string;
    time: string;
    logo: string;
    text: string;
    largeText?: string[];
    github: string;
    demo?: string;
    screenshot?: string;
    technologies: Array<{
      name: string;
      logo: string;
    }>;
  }>;
  idPrefix?: string;
}

const { projects, idPrefix = '' } = Astro.props;
---

<section>
  <div>
    {projects.map((project, index) => (
      <div>
        <input type="checkbox" id={`project-modal-${idPrefix}${index}`} class="modal-toggle" />

        <label for={`project-modal-${idPrefix}${index}`} class="card card-clickable work-card">
          <p class="work-time">{project.time}</p>
          <h3 class="work-title">{project.name}</h3>
          <div class="stack">
            {project.screenshot && (
              <img src={project.screenshot} alt={`${project.name} screenshot`} class="project-shot" loading="lazy" decoding="async" />
            )}
            <p>{project.text}</p>

            <div>
              <h4>TECH STACK:</h4>
              <div class="flex wrap">
                {project.technologies.map((tech) => (
                  <span class="tag" data-category={tech.category}>{tech.name}</span>
                ))}
              </div>
            </div>
          </div>
        </label>
        
        <div class="modal">
          <div class="modal-content">
            <button class="close" onclick={`document.getElementById('project-modal-${idPrefix}${index}').checked=false`}>×</button>
            <div class="work-header">
              <h3>{project.name}</h3>
              <p class="work-time">{project.time}</p>
            </div>
            
            <div>
              <h4>DESCRIPTION:</h4>
              <p>{project.text}</p>
              {project.largeText && project.largeText.map((text) => (
                <p>{text}</p>
              ))}
            </div>
            
            <div class="stack">
              <h4>TECHNOLOGIES:</h4>
              <div class="flex wrap">
                {project.technologies.map((tech) => (
                  <span class="tag" data-category={tech.category}>{tech.name}</span>
                ))}
              </div>
            </div>
            
            <div class="project-links">
              <a href={project.github} target="_blank" rel="noopener noreferrer">
                VIEW CODE →
              </a>
              {project.demo && (
                <a href={project.demo} target="_blank" rel="noopener noreferrer">
                  LIVE DEMO →
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>