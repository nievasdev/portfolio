---
export interface Props {
  works: Array<{
    name: string;
    time: string;
    logo: string;
    text: string;
    tagline?: string;
    highlights?: string[];
    largeText: string[];
    workMethod: string;
    projects: Array<{
      title: string;
      text: string;
    }>;
    technologies: Array<{
      name: string;
      logo: string;
    }>;
    stats?: Array<{
      value: string;
      label: string;
    }>;
  }>;
  lang?: string;
}

const { works, lang = 'en' } = Astro.props;
---

<section>
  <div>
    {works.map((work, index) => (
    <a
      href={`/work/${index}-${lang}`}
      class="card card-clickable work-card"
    >
        <p class="work-time">{work.time}</p>
        <h3 class="work-title">{work.name}</h3>
        <div class="work-main">
          <div class="work-title-section">
            {work.logo && (
              <div class="work-logo-container">
                <img src={work.logo} alt={`${work.name} logo`} class="work-logo" width="80" height="80" />
              </div>
            )}
          </div>
          {work.tagline && <p class="desc work-tagline">{work.tagline}</p>}
          {work.stats && work.stats.length > 0 && (
            <div class="stats-row">
              {work.stats.map((stat) => (
                <div class="stat">
                  <b>{stat.value}</b>
                  <span>{stat.label}</span>
                </div>
              ))}
            </div>
          )}
          {work.highlights && work.highlights.length > 0 && (
            <ul class="work-description">
              {work.highlights.slice(0, 2).map((text: string) => (
                <li>{text}</li>
              ))}
            </ul>
          )}
          {work.technologies && work.technologies.length > 0 && (
            <div class="flex wrap work-tags">
              {work.technologies.map((tech: any) => (
                <span class="tag" data-category={tech.category}>{tech.name}</span>
              ))}
            </div>
          )}
        </div>
      </a>
    ))}
  </div>
</section>
